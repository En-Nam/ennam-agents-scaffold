{
  "name": "@ennamjsc/agents-scaffold",
  "version": "1.9.0",
  "description": "Install Claude Code tooling into existing projects",
  "type": "module",
  "license": "SEE LICENSE IN README.md",
  "homepage": "https://github.com/En-Nam/ennam-agents-scaffold#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/En-Nam/ennam-agents-scaffold.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/En-Nam/ennam-agents-scaffold/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "scaffold",
    "agents",
    "superpowers",
    "serena",
    "mcp",
    "cli"
  ],
  "bin": {
    "ennam-agents-scaffold": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "execa": "^9.6.1",
    "strip-ansi": "^7.2.0",
    "tmp-promise": "^3.0.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "cac": "^6.7.14",
    "fast-glob": "^3.3.3",
    "handlebars": "^4.7.9",
    "picocolors": "^1.1.1"
  }
}
