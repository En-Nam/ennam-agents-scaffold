{
  "permissions": {
    "additionalAllowList": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(git:*)"
    ]
  },
  "model": "claude-opus-4-7",
  "outputStyle": "default",
  "enabledPlugins": {
    "github@claude-plugins-official": true
  },
  "hooks": {
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/subagent-log.ps1"
          }
        ]
      }
    ]
  }
}
